#:kivy 2.0.0

<ControllerRow@BoxLayout>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(60)
    padding: dp(5)
    spacing: dp(10)
    canvas.before:
        Color:
            rgba: 0.2, 0.2, 0.2, 1
        Rectangle:
            pos: self.pos
            size: self.size

    controller_id: ""
    ip: ""
    osc_port: 0
    channels: 0
    status: ""
    
    # Let parent handle up/down actions
    app_ref: app

    Label:
        text: "ON" if root.status == 'online' else "OFF"
        color: (0, 1, 0, 1) if root.status == 'online' else (1, 0, 0, 1)
        bold: True
        size_hint_x: None
        width: dp(40)
        font_size: dp(14)

    BoxLayout:
        orientation: 'vertical'
        Label:
            text: root.controller_id
            bold: True
            halign: 'left'
            valign: 'bottom'
            text_size: self.size
        Label:
            text: f"{root.ip}:{root.osc_port}  |  {root.channels} Kanäle"
            color: 0.7, 0.7, 0.7, 1
            font_size: dp(12)
            halign: 'left'
            valign: 'top'
            text_size: self.size

    Button:
        text: "Up"
        font_size: dp(12)
        size_hint_x: None
        width: dp(45)
        on_release: root.app_ref.move_controller_up(root.controller_id)

    Button:
        text: "Down"
        font_size: dp(12)
        size_hint_x: None
        width: dp(45)
        on_release: root.app_ref.move_controller_down(root.controller_id)


<BrokerRoot@BoxLayout>:
    orientation: 'vertical'
    padding: dp(10)
    spacing: dp(10)

    canvas.before:
        Color:
            rgba: 0.1, 0.1, 0.1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    Label:
        text: "DAWDesk Broker"
        font_size: dp(24)
        bold: True
        size_hint_y: None
        height: dp(40)

    ScrollView:
        size_hint_y: 0.5
        BoxLayout:
            id: controller_list
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            spacing: dp(5)


    Label:
        text: "Log Output"
        font_size: dp(16)
        bold: True
        size_hint_y: None
        height: dp(30)
        halign: 'left'
        valign: 'middle'
        text_size: self.size

    TextInput:
        id: log_output
        size_hint_y: 0.5
        readonly: True
        text: app.log_text
        background_color: 0.15, 0.15, 0.15, 1
        foreground_color: 0.8, 0.8, 0.8, 1
        font_name: 'RobotoMono-Regular' # Or any monospaced font if available, fallback to default
        font_size: dp(12)
