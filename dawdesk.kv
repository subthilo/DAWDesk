#:kivy 2.3.1

# -------------------------------------------------------------------------
# UI-Definition für DAWDesk
# High-Performance Single-Widget Architecture
# -------------------------------------------------------------------------
#:import MixerLayout widgets.mixer_layout.MixerLayout
#:import Toolbar widgets.toolbar.Toolbar

DAWDeskRoot:

<DAWChannelStrip>:
    # Kein Layout, keine Child-Widgets!
    # Alles wird in Python direkt auf den Canvas gezeichnet.

<MixerLayout>:
    orientation: 'horizontal'
    padding: 10
    spacing: 5
    canvas.before:
        Color:
            rgba: 0.05, 0.08, 0.12, 1
        Rectangle:
            pos: self.pos
            size: self.size

<DAWDeskRoot@BoxLayout>:
    orientation: 'vertical'
    
    # Obere Toolbar
    Toolbar:
        size_hint_y: None
        height: 60
        padding: 5
        spacing: 10
        canvas.before:
            Color:
                rgba: 0.15, 0.2, 0.25, 1
            Rectangle:
                pos: self.pos
                size: self.size
                
        Label:
            text: app.connection_status
            font_size: 18
            bold: True
            halign: 'left'
            valign: 'middle'
            text_size: self.size
            size_hint_x: 0.8
            
        Label:
            text: "SWIPE TO NUDGE"
            font_size: 14
            color: 0.5, 0.5, 0.5, 1
            size_hint_x: 0.2

    # Hauptbereich: Mixer
    MixerLayout:
        id: mixer_layout
