#:kivy 2.3.1

# -------------------------------------------------------------------------
# UI-Definition für DAWDesk
# High-Performance Single-Widget Architecture
# -------------------------------------------------------------------------
#:import MixerLayout widgets.mixer_layout.MixerLayout
#:import Toolbar widgets.toolbar.Toolbar
#:import ActionRow widgets.action_row.ActionRow

DAWDeskRoot:

<DAWChannelStrip>:
    # Kein Layout, keine Child-Widgets!
    # Alles wird in Python direkt auf den Canvas gezeichnet.

<MixerLayout>:
    orientation: 'horizontal'
    padding: 10
    spacing: 5
    canvas.before:
        Color:
            rgba: 0.05, 0.08, 0.12, 1
        Rectangle:
            pos: self.pos
            size: self.size

<DAWDeskRoot@BoxLayout>:
    orientation: 'vertical'

    # Hauptbereich: Mixer
    MixerLayout:
        id: mixer_layout

    # Action Row (Nudge, Ebenen)
    ActionRow:
        id: action_row
